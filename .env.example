# ========================================
# BANCO DE DADOS E AUTENTICAÇÃO (SaaS)
# ========================================
# Crie um projeto em supabase.com e pegue as chaves em Project Settings -> API
SUPABASE_URL=seu_url_supabase_aqui
SUPABASE_anon_key=sua_anon_key_aqui
SUPABASE_SECRET_ROLE=sua_service_role_key_aqui
DEMO_LOGIN_ENABLED=false
# ========================================
# CHAVES DE INTELIGÊNCIA (IA)
# ========================================
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sua_chave_openrouter_aqui
# Modelo focado em Criatividade (Copiloto/Posts)
OPENROUTER_MODEL=meta-llama/llama-3-70b-instruct
# Modelo focado em Análise e Alto Contexto (Eva Brain)
OPENROUTER_ANALYSIS_MODEL=minimax/minimax-01

# ========================================
# FERRAMENTAS DO ECOSSISTEMA
# ========================================

# Buffer (Redes Sociais)
BUFFER_API_KEY=sua_chave_buffer_aqui

# Signal (CRM / Automação Email)
SIGNAL_API_URL=https://api.signal.ai/leads

# Eva Brain (Ads)
EVA_BRAIN_API_KEY=sua_chave_eva_brain_aqui

# Stormy (Influenciadores)
STORMY_API_KEY=sua_chave_stormy_aqui

# ========================================
# CONFIGURAÇÕES GERAIS
# ========================================
CEO_EMAIL=ceo@suaempresa.com.br
